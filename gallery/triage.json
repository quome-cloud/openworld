  "initial_state": {
    "tick": 0,
    "critical_waiting": 4,
    "moderate_waiting": 8,
    "treated": 0,
    "deteriorated": 0,
    "outcomes": 0,
    "spend": 0
  },
  "actions": [
    "treat_critical",
    "treat_moderate",
    "wait"
  ],
  "rules": [
    "'treat_critical' treats one waiting critical patient: critical_waiting -1, treated +1, outcomes +3, spend +3.",
    "'treat_moderate' treats one waiting moderate patient: moderate_waiting -1, treated +1, outcomes +1, spend +1.",
    "Treating when the matching queue is empty does nothing (besides the clock).",
    "After EVERY action (including 'wait' and 'noop'), tick increases by 1.",
    "Whenever the new tick is even and critical patients still wait, one of them deteriorates: critical_waiting -1, deteriorated +1, outcomes -2."
  ],
  "transition": {
    "kind": "code",
    "func_name": "triage_ground_truth",
    "code": "def triage_ground_truth(state, action):\n    s = dict(state)\n    name = action[\"name\"]\n    if name == \"treat_critical\" and s[\"critical_waiting\"] > 0:\n        s[\"critical_waiting\"] -= 1\n        s[\"treated\"] += 1\n        s[\"outcomes\"] += 3\n        s[\"spend\"] += 3\n    elif name == \"treat_moderate\" and s[\"moderate_waiting\"] > 0:\n        s[\"moderate_waiting\"] -= 1\n        s[\"treated\"] += 1\n        s[\"outcomes\"] += 1\n        s[\"spend\"] += 1\n    s[\"tick\"] += 1\n    if s[\"tick\"] % 2 == 0 and s[\"critical_waiting\"] > 0:\n        s[\"critical_waiting\"] -= 1\n        s[\"deteriorated\"] += 1\n        s[\"outcomes\"] -= 2\n    return s\n",
    "from_function": true
  },
