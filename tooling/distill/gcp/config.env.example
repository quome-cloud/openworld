# Copy to config.env and edit. config.env is gitignored — NEVER commit real values.
# Nothing here is a secret (project/zone are not credentials); auth comes from your
# local `gcloud auth login`, which is never copied to the VM.

# --- GCP target ---------------------------------------------------------------
PROJECT="$(gcloud config get-value project 2>/dev/null)"   # or hard-set, e.g. my-sandbox
ZONE="us-central1-a"           # must have the chosen GPU's spot capacity + quota
VM_NAME="ow-a100-harvest"

# --- machine ------------------------------------------------------------------
# Default: 2x NVIDIA A100 40GB (80GB total) — fits a 70B Q4 teacher and is within
# typical A100 spot quota. The GPUs are part of the a2 machine type (no
# --accelerator flag). Spot to minimize cost; auto-deleted on preemption.
#   a2-highgpu-2g = 2x A100 40GB  (this default)
#   a3-highgpu-1g = 1x H100 80GB  (needs H100 quota; set the metric below to match)
MACHINE_TYPE="a2-highgpu-2g"
GPU_QUOTA_METRIC="PREEMPTIBLE_NVIDIA_A100_GPUS"   # provision.sh preflights this
GPU_COUNT="2"                                     # GPUs this machine type needs
BOOT_DISK_GB="200"             # DLVM image + 40GB model + headroom
# CUDA-ready Deep Learning VM image (driver auto-installs on first boot).
# Override if the family has rolled; list with:
#   gcloud compute images list --project deeplearning-platform-release --filter=cu12
IMAGE_FAMILY="common-cu129-ubuntu-2204-nvidia-580"
IMAGE_PROJECT="deeplearning-platform-release"

# --- harvest ------------------------------------------------------------------
TEACHER_MODEL="llama3.1:70b"   # official weights — NOT a *-poisoned* variant
RECIPES="owsb-atomic-v1 owsb-staged-v1"
SEEDS="5"
TRACE_DIR="traces/harvest-70b" # produced on the VM, copied back to ./<TRACE_DIR>
